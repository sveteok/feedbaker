{
  "name": "feedbaker",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:client": "pnpm --filter @feedbaker/client dev",
    "dev:server": "pnpm --filter @feedbaker/server dev",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@8.3.0": "8.4.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@5.0.4": "5.0.5",
      "vite": "7.3.2"
    }
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
